# Database
DATABASE_URL=postgresql://kd_user:kd_secret@localhost:5432/karibdocs

# Security / JWT
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM settings
LLM_PROVIDER=ollama
LLM_TEMPERATURE=0.1
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/drive/oauth/callback

# Storage
UPLOAD_DIR=./uploads
CHROMA_DIR=./chroma_db
MAX_FILE_SIZE_MB=50

# RAG settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RAG_K_RESULTS=4
EMBEDDING_PROVIDER=huggingface
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
